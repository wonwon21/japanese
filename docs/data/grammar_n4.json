{
  "level": "N4",
  "title": "N4 문법 — 중급 진입 문형",
  "items": [
    {"pattern":"가능형 (〜れる / 〜られる)","ko":"~할 수 있다","conn":"1그룹: う단→え단+る / 2그룹: られる","ex":[{"jp":"日本語が話せます。","ko":"일본어를 할 수 있습니다."},{"jp":"漢字が読めますか。","ko":"한자를 읽을 수 있습니까?"}],"note":"가능형에서는 목적어 조사가 を→が로 바뀌는 경우가 많음"},
    {"pattern":"〜ことができる","ko":"~하는 것이 가능하다","conn":"사전형 + ことができる","ex":[{"jp":"ここで写真を撮ることができます。","ko":"여기서 사진을 찍을 수 있습니다."},{"jp":"彼はピアノを弾くことができます。","ko":"그는 피아노를 칠 수 있습니다."}]},
    {"pattern":"의지형 (〜(よ)う)","ko":"~하자, ~해야지 (반말 청유·의지)","conn":"1그룹: う단→お단+う / 2그룹: よう","ex":[{"jp":"一緒に行こう。","ko":"같이 가자."},{"jp":"明日から早く起きよう。","ko":"내일부터 일찍 일어나야지."}]},
    {"pattern":"〜(よ)うと思う","ko":"~하려고 생각하다","conn":"의지형 + と思う","ex":[{"jp":"夏休みに日本へ行こうと思います。","ko":"여름방학에 일본에 가려고 합니다."},{"jp":"今日は早く寝ようと思う。","ko":"오늘은 일찍 자려고 해."}]},
    {"pattern":"〜つもりだ","ko":"~할 작정이다, ~할 생각이다","conn":"사전형 + つもりだ","ex":[{"jp":"来年、留学するつもりです。","ko":"내년에 유학할 생각입니다."},{"jp":"タバコはやめるつもりです。","ko":"담배는 끊을 작정입니다."}]},
    {"pattern":"〜予定だ","ko":"~할 예정이다","conn":"사전형/명사の + 予定だ","ex":[{"jp":"3時に着く予定です。","ko":"3시에 도착할 예정입니다."},{"jp":"会議は明日の予定です。","ko":"회의는 내일 예정입니다."}]},
    {"pattern":"〜と思う","ko":"~라고 생각하다","conn":"보통형 + と思う","ex":[{"jp":"明日は雨が降ると思います。","ko":"내일은 비가 올 거라고 생각합니다."},{"jp":"この映画はおもしろいと思う。","ko":"이 영화는 재미있다고 생각해."}]},
    {"pattern":"〜かもしれない","ko":"~일지도 모른다","conn":"보통형 + かもしれない","ex":[{"jp":"午後は雨が降るかもしれません。","ko":"오후에는 비가 올지도 모릅니다."},{"jp":"彼は来ないかもしれない。","ko":"그는 안 올지도 몰라."}]},
    {"pattern":"〜でしょう","ko":"~겠지요, ~일 것입니다","conn":"보통형 + でしょう","ex":[{"jp":"明日は晴れるでしょう。","ko":"내일은 맑겠지요."},{"jp":"彼はもうすぐ来るでしょう。","ko":"그는 곧 올 거예요."}]},
    {"pattern":"〜そうだ (양태)","ko":"~해 보인다, ~할 것 같다","conn":"동사 어간/형용사 어간 + そうだ","ex":[{"jp":"雨が降りそうです。","ko":"비가 올 것 같습니다."},{"jp":"このケーキはおいしそうですね。","ko":"이 케이크는 맛있어 보이네요."}],"note":"눈으로 보고 판단하는 '~해 보인다'"},
    {"pattern":"〜そうだ (전문)","ko":"~라고 한다 (들은 정보)","conn":"보통형 + そうだ","ex":[{"jp":"ニュースによると、台風が来るそうです。","ko":"뉴스에 따르면 태풍이 온다고 합니다."},{"jp":"彼は結婚したそうだ。","ko":"그는 결혼했다고 한다."}],"note":"양태와 접속이 다름: 降りそう(양태) vs 降るそう(전문)"},
    {"pattern":"〜ようだ / 〜みたいだ","ko":"~인 것 같다 (추측·비유)","conn":"보통형 + ようだ/みたいだ","ex":[{"jp":"誰か来たようです。","ko":"누군가 온 것 같습니다."},{"jp":"彼は疲れているみたいだ。","ko":"그는 피곤한 것 같아."}],"note":"みたいだ가 더 회화체"},
    {"pattern":"〜らしい","ko":"~인 듯하다, ~답다","conn":"보통형/명사 + らしい","ex":[{"jp":"あの店はおいしいらしいです。","ko":"저 가게는 맛있다는 것 같습니다."},{"jp":"今日は春らしい天気ですね。","ko":"오늘은 봄다운 날씨네요."}]},
    {"pattern":"수동형 (〜れる / 〜られる)","ko":"~당하다, ~되다 (수동)","conn":"1그룹: あ단+れる / 2그룹: られる","ex":[{"jp":"先生にほめられました。","ko":"선생님께 칭찬받았습니다."},{"jp":"弟にケーキを食べられた。","ko":"남동생이 (내) 케이크를 먹어 버렸다(피해수동)."}],"note":"⚠️ 한국어보다 수동을 훨씬 자주 씀. 피해의 뉘앙스도 있음"},
    {"pattern":"사역형 (〜せる / 〜させる)","ko":"~하게 하다, ~시키다","conn":"1그룹: あ단+せる / 2그룹: させる","ex":[{"jp":"母は弟に野菜を食べさせました。","ko":"어머니는 남동생에게 채소를 먹게 했습니다."},{"jp":"先生は学生に作文を書かせた。","ko":"선생님은 학생에게 작문을 쓰게 했다."}]},
    {"pattern":"사역수동 (〜させられる)","ko":"(억지로) ~하게 되다","conn":"사역형 + られる","ex":[{"jp":"歌を歌わせられました。","ko":"(억지로) 노래를 부르게 되었습니다."},{"jp":"子供のとき、ピアノを習わせられた。","ko":"어렸을 때 억지로 피아노를 배웠다."}],"note":"'시켜서 억지로 했다'는 뉘앙스"},
    {"pattern":"명령형","ko":"~해라 (강한 명령)","conn":"1그룹: う단→え단 / 2그룹: ろ","ex":[{"jp":"早く起きろ！","ko":"빨리 일어나!"},{"jp":"頑張れ！","ko":"힘내라!"}],"note":"매우 강한 말투. 응원 구호로도 씀"},
    {"pattern":"〜な (금지)","ko":"~하지 마라","conn":"사전형 + な","ex":[{"jp":"ここに入るな。","ko":"여기 들어오지 마."},{"jp":"あきらめるな。","ko":"포기하지 마."}]},
    {"pattern":"〜なさい","ko":"~하렴, ~하세요 (가벼운 명령)","conn":"동사 어간 + なさい","ex":[{"jp":"早く寝なさい。","ko":"빨리 자렴."},{"jp":"野菜も食べなさい。","ko":"채소도 먹으렴."}],"note":"부모→자식, 선생→학생에게 쓰는 부드러운 명령"},
    {"pattern":"〜と (조건)","ko":"~하면 (반드시·자연법칙)","conn":"사전형 + と","ex":[{"jp":"春になると、花が咲きます。","ko":"봄이 되면 꽃이 핍니다."},{"jp":"このボタンを押すと、ドアが開きます。","ko":"이 버튼을 누르면 문이 열립니다."}]},
    {"pattern":"〜ば (조건)","ko":"~하면 (가정)","conn":"1그룹: え단+ば / い형용사: ければ","ex":[{"jp":"安ければ買います。","ko":"싸면 삽니다."},{"jp":"急げば間に合いますよ。","ko":"서두르면 늦지 않아요."}]},
    {"pattern":"〜たら (조건)","ko":"~하면, ~했더니","conn":"た형 + ら","ex":[{"jp":"雨が降ったら、行きません。","ko":"비가 오면 안 갑니다."},{"jp":"家に帰ったら、電話してください。","ko":"집에 돌아가면 전화해 주세요."}],"note":"조건 4형제 중 가장 넓게 쓰임. 고민되면 たら"},
    {"pattern":"〜なら (조건)","ko":"~라면 (화제 조건)","conn":"명사/보통형 + なら","ex":[{"jp":"日本に行くなら、京都がおすすめです。","ko":"일본에 간다면 교토를 추천합니다."},{"jp":"寿司なら、あの店がおいしいです。","ko":"초밥이라면 저 가게가 맛있습니다."}]},
    {"pattern":"〜ても","ko":"~해도","conn":"て형 + も","ex":[{"jp":"高くても買います。","ko":"비싸도 삽니다."},{"jp":"雨が降っても行きます。","ko":"비가 와도 갑니다."}]},
    {"pattern":"〜のに","ko":"~인데도 (역접·의외)","conn":"보통형 + のに","ex":[{"jp":"薬を飲んだのに、治りません。","ko":"약을 먹었는데도 낫지 않습니다."},{"jp":"約束したのに、彼は来なかった。","ko":"약속했는데도 그는 오지 않았다."}],"note":"불만·의외의 감정이 담김"},
    {"pattern":"〜ので","ko":"~이기 때문에","conn":"보통형 + ので (な형용사·명사는 +なので)","ex":[{"jp":"頭が痛いので、早く帰ります。","ko":"머리가 아파서 일찍 돌아갑니다."},{"jp":"明日は休みなので、ゆっくり寝ます。","ko":"내일은 쉬는 날이라서 푹 잡니다."}],"note":"から보다 부드럽고 정중한 이유 표현"},
    {"pattern":"〜し","ko":"~하고 (이유 나열)","conn":"보통형 + し","ex":[{"jp":"この店は安いし、おいしいです。","ko":"이 가게는 싸고 맛있습니다."},{"jp":"雨も降っているし、今日は家にいよう。","ko":"비도 오고 하니 오늘은 집에 있자."}]},
    {"pattern":"〜ておく","ko":"~해 두다 (준비)","conn":"て형 + おく","ex":[{"jp":"旅行の前にホテルを予約しておきます。","ko":"여행 전에 호텔을 예약해 둡니다."},{"jp":"ビールを冷やしておきました。","ko":"맥주를 차게 해 두었습니다."}],"note":"회화에서 〜とく로 줄여 말함"},
    {"pattern":"〜てある","ko":"~해져 있다 (누군가 해 놓은 상태)","conn":"타동사 て형 + ある","ex":[{"jp":"壁にカレンダーがかけてあります。","ko":"벽에 달력이 걸려 있습니다."},{"jp":"ドアに名前が書いてあります。","ko":"문에 이름이 쓰여 있습니다."}]},
    {"pattern":"〜てしまう","ko":"~해 버리다 (완료·후회)","conn":"て형 + しまう","ex":[{"jp":"宿題を忘れてしまいました。","ko":"숙제를 잊어버렸습니다."},{"jp":"ケーキを全部食べてしまった。","ko":"케이크를 다 먹어 버렸다."}],"note":"회화에서 〜ちゃう로 줄여 말함"},
    {"pattern":"〜てみる","ko":"~해 보다 (시도)","conn":"て형 + みる","ex":[{"jp":"この服を着てみてもいいですか。","ko":"이 옷을 입어 봐도 됩니까?"},{"jp":"納豆を食べてみました。","ko":"낫토를 먹어 봤습니다."}]},
    {"pattern":"〜あげる / くれる / もらう","ko":"주다 / (나에게) 주다 / 받다","conn":"명사 + を + あげる/くれる/もらう","ex":[{"jp":"友達にプレゼントをあげました。","ko":"친구에게 선물을 줬습니다."},{"jp":"母が弁当を作ってくれました。","ko":"어머니가 도시락을 만들어 주셨습니다."}],"note":"⚠️ 한국어와 갈라지는 지점: 남→나 방향은 반드시 くれる"},
    {"pattern":"〜ていただけませんか","ko":"~해 주시지 않겠습니까? (정중 부탁)","conn":"て형 + いただけませんか","ex":[{"jp":"もう一度説明していただけませんか。","ko":"다시 한번 설명해 주시지 않겠습니까?"},{"jp":"写真を撮っていただけませんか。","ko":"사진을 찍어 주시겠어요?"}]},
    {"pattern":"〜させてください","ko":"~하게 해 주세요","conn":"사역형 て형 + ください","ex":[{"jp":"今日は早く帰らせてください。","ko":"오늘은 일찍 돌아가게 해 주세요."},{"jp":"私に払わせてください。","ko":"제가 내게 해 주세요."}]},
    {"pattern":"〜方 (かた)","ko":"~하는 방법","conn":"동사 어간 + 方","ex":[{"jp":"この漢字の書き方を教えてください。","ko":"이 한자 쓰는 법을 가르쳐 주세요."},{"jp":"使い方が分かりません。","ko":"사용법을 모르겠습니다."}]},
    {"pattern":"〜やすい / 〜にくい","ko":"~하기 쉽다 / ~하기 어렵다","conn":"동사 어간 + やすい/にくい","ex":[{"jp":"この本は読みやすいです。","ko":"이 책은 읽기 쉽습니다."},{"jp":"この靴は歩きにくいです。","ko":"이 신발은 걷기 불편합니다."}]},
    {"pattern":"〜すぎる","ko":"너무 ~하다","conn":"동사·형용사 어간 + すぎる","ex":[{"jp":"食べすぎました。","ko":"너무 많이 먹었습니다."},{"jp":"この問題は難しすぎます。","ko":"이 문제는 너무 어렵습니다."}]},
    {"pattern":"〜ことにする","ko":"~하기로 하다 (내 결정)","conn":"사전형 + ことにする","ex":[{"jp":"毎日運動することにしました。","ko":"매일 운동하기로 했습니다."},{"jp":"タバコをやめることにした。","ko":"담배를 끊기로 했다."}]},
    {"pattern":"〜ことになる","ko":"~하게 되다 (외부 결정)","conn":"사전형 + ことになる","ex":[{"jp":"来月、大阪に転勤することになりました。","ko":"다음 달 오사카로 전근하게 되었습니다."},{"jp":"会議は金曜日に行われることになった。","ko":"회의는 금요일에 열리게 되었다."}]},
    {"pattern":"〜ようにする","ko":"~하도록 하다 (노력)","conn":"사전형/ない형 + ようにする","ex":[{"jp":"毎日野菜を食べるようにしています。","ko":"매일 채소를 먹도록 하고 있습니다."},{"jp":"遅れないようにしてください。","ko":"늦지 않도록 해 주세요."}]},
    {"pattern":"〜ようになる","ko":"~할 수 있게 되다 (변화)","conn":"사전형/가능형 + ようになる","ex":[{"jp":"日本語が話せるようになりました。","ko":"일본어를 할 수 있게 되었습니다."},{"jp":"納豆が食べられるようになった。","ko":"낫토를 먹을 수 있게 되었다."}]},
    {"pattern":"〜かどうか","ko":"~인지 어떤지","conn":"보통형 + かどうか","ex":[{"jp":"行くかどうか、まだ決めていません。","ko":"갈지 어떨지 아직 정하지 않았습니다."},{"jp":"正しいかどうか確認してください。","ko":"맞는지 어떤지 확인해 주세요."}]},
    {"pattern":"의문사 + か","ko":"~인지 (간접의문)","conn":"의문사 + 보통형 + か","ex":[{"jp":"何時に来るか知っていますか。","ko":"몇 시에 오는지 알고 있습니까?"},{"jp":"どこに住んでいるか教えてください。","ko":"어디에 사는지 알려 주세요."}]},
    {"pattern":"〜という","ko":"~라는","conn":"명사 + という + 명사","ex":[{"jp":"田中さんという人が来ました。","ko":"다나카 씨라는 사람이 왔습니다."},{"jp":"「ハナ」というカフェを知っていますか。","ko":"'하나'라는 카페를 알고 있습니까?"}]},
    {"pattern":"〜ため(に) (목적)","ko":"~을 위해서","conn":"사전형/명사の + ために","ex":[{"jp":"家族のために働いています。","ko":"가족을 위해서 일하고 있습니다."},{"jp":"日本に留学するために、お金をためています。","ko":"일본 유학을 위해 돈을 모으고 있습니다."}]},
    {"pattern":"〜までに","ko":"~까지 (기한)","conn":"명사/사전형 + までに","ex":[{"jp":"金曜日までにレポートを出してください。","ko":"금요일까지 리포트를 내 주세요."},{"jp":"5時までに帰ります。","ko":"5시까지는 돌아갑니다."}],"note":"まで(계속)와 までに(기한)의 구분에 주의"},
    {"pattern":"〜はずだ","ko":"~일 것이다 (근거 있는 확신)","conn":"보통형 + はずだ","ex":[{"jp":"彼はもう着いているはずです。","ko":"그는 이미 도착했을 것입니다."},{"jp":"この時間なら店は開いているはずだ。","ko":"이 시간이면 가게는 열려 있을 것이다."}]},
    {"pattern":"〜はずがない","ko":"~일 리가 없다","conn":"보통형 + はずがない","ex":[{"jp":"彼がうそをつくはずがありません。","ko":"그가 거짓말을 할 리가 없습니다."},{"jp":"そんなはずがない！","ko":"그럴 리가 없어!"}]},
    {"pattern":"존경어 기초 (お〜になる 등)","ko":"~하시다","conn":"お + 동사 어간 + になる","ex":[{"jp":"先生はもうお帰りになりました。","ko":"선생님은 벌써 돌아가셨습니다."},{"jp":"こちらをご覧ください。","ko":"이쪽을 봐 주십시오."}],"note":"いらっしゃる(계시다), おっしゃる(말씀하시다) 등 특수 존경어도 함께"},
    {"pattern":"겸양어 기초 (お〜する 등)","ko":"~해 드리다 (자신을 낮춤)","conn":"お + 동사 어간 + する","ex":[{"jp":"荷物をお持ちします。","ko":"짐을 들어 드리겠습니다."},{"jp":"後でお電話します。","ko":"나중에 전화드리겠습니다."}],"note":"いたす(하다), まいる(가다/오다), いただく(받다/먹다) 등"}
  ]
}
