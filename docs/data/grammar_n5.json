{
  "level": "N5",
  "title": "N5 문법 — 기초 문형",
  "items": [
    {"pattern":"〜は〜です","ko":"~는 ~입니다","conn":"명사 + は + 명사 + です","ex":[{"jp":"私は学生です。","rom":"Watashi wa gakusei desu.","ko":"저는 학생입니다."},{"jp":"これは本です。","rom":"Kore wa hon desu.","ko":"이것은 책입니다."}],"note":"は는 한국어 '는/은'과 동일. 발음은 'wa'"},
    {"pattern":"〜じゃありません / ではありません","ko":"~이 아닙니다","conn":"명사 + じゃありません","ex":[{"jp":"私は日本人じゃありません。","rom":"Watashi wa Nihonjin ja arimasen.","ko":"저는 일본인이 아닙니다."},{"jp":"ここは学校ではありません。","rom":"Koko wa gakkō de wa arimasen.","ko":"여기는 학교가 아닙니다."}],"note":"ではありません이 더 격식체"},
    {"pattern":"〜でした / じゃありませんでした","ko":"~였습니다 / ~이 아니었습니다","conn":"명사 + でした","ex":[{"jp":"昨日は雨でした。","rom":"Kinō wa ame deshita.","ko":"어제는 비였습니다."},{"jp":"テストは簡単じゃありませんでした。","rom":"Tesuto wa kantan ja arimasen deshita.","ko":"시험은 간단하지 않았습니다."}]},
    {"pattern":"〜が","ko":"~이/가 (주격 조사)","conn":"명사 + が","ex":[{"jp":"猫がいます。","rom":"Neko ga imasu.","ko":"고양이가 있습니다."},{"jp":"雨が降っています。","rom":"Ame ga futte imasu.","ko":"비가 내리고 있습니다."}],"note":"한국어 '이/가'와 1:1 대응"},
    {"pattern":"〜を","ko":"~을/를 (목적격 조사)","conn":"명사 + を + 타동사","ex":[{"jp":"パンを食べます。","rom":"Pan o tabemasu.","ko":"빵을 먹습니다."},{"jp":"本を読みます。","rom":"Hon o yomimasu.","ko":"책을 읽습니다."}],"note":"한국어 '을/를'과 1:1 대응. 발음은 'o'"},
    {"pattern":"〜に (장소·시간)","ko":"~에 (존재 장소, 시각)","conn":"명사 + に","ex":[{"jp":"7時に起きます。","rom":"Shichiji ni okimasu.","ko":"7시에 일어납니다."},{"jp":"部屋に猫がいます。","rom":"Heya ni neko ga imasu.","ko":"방에 고양이가 있습니다."}],"note":"한국어 '에'와 대응"},
    {"pattern":"〜に (대상·방향)","ko":"~에게, ~에 (이동 방향)","conn":"명사 + に","ex":[{"jp":"友達に電話します。","rom":"Tomodachi ni denwa shimasu.","ko":"친구에게 전화합니다."},{"jp":"学校に行きます。","rom":"Gakkō ni ikimasu.","ko":"학교에 갑니다."}]},
    {"pattern":"〜で (장소)","ko":"~에서 (동작 장소)","conn":"명사 + で + 동작동사","ex":[{"jp":"図書館で勉強します。","rom":"Toshokan de benkyō shimasu.","ko":"도서관에서 공부합니다."},{"jp":"食堂でごはんを食べます。","rom":"Shokudō de gohan o tabemasu.","ko":"식당에서 밥을 먹습니다."}],"note":"한국어 '에서'와 대응. に(존재)와 구분: いる/ある는 に, 동작은 で"},
    {"pattern":"〜で (수단)","ko":"~으로 (수단·도구)","conn":"명사 + で","ex":[{"jp":"バスで行きます。","rom":"Basu de ikimasu.","ko":"버스로 갑니다."},{"jp":"日本語で話してください。","rom":"Nihongo de hanashite kudasai.","ko":"일본어로 말해 주세요."}]},
    {"pattern":"〜と","ko":"~와/과","conn":"명사 + と + 명사","ex":[{"jp":"友達と映画を見ます。","rom":"Tomodachi to eiga o mimasu.","ko":"친구와 영화를 봅니다."},{"jp":"パンと牛乳を買いました。","rom":"Pan to gyūnyū o kaimashita.","ko":"빵과 우유를 샀습니다."}]},
    {"pattern":"〜も","ko":"~도","conn":"명사 + も","ex":[{"jp":"私も行きます。","rom":"Watashi mo ikimasu.","ko":"저도 갑니다."},{"jp":"彼も学生です。","rom":"Kare mo gakusei desu.","ko":"그도 학생입니다."}]},
    {"pattern":"〜の (소유)","ko":"~의","conn":"명사 + の + 명사","ex":[{"jp":"私の本です。","rom":"Watashi no hon desu.","ko":"제 책입니다."},{"jp":"日本の車は有名です。","rom":"Nihon no kuruma wa yūmei desu.","ko":"일본의 차는 유명합니다."}],"note":"한국어는 '의'를 자주 생략하지만 일본어 の는 생략 불가"},
    {"pattern":"〜へ","ko":"~에, ~으로 (방향)","conn":"명사 + へ","ex":[{"jp":"日本へ行きます。","rom":"Nihon e ikimasu.","ko":"일본에 갑니다."},{"jp":"どこへ行きますか。","rom":"Doko e ikimasu ka.","ko":"어디에 가요?"}],"note":"발음은 'e'. に로 바꿔 써도 대부분 OK"},
    {"pattern":"〜から / 〜まで","ko":"~부터 / ~까지","conn":"명사 + から / まで","ex":[{"jp":"9時から5時まで働きます。","rom":"Kuji kara goji made hatarakimasu.","ko":"9시부터 5시까지 일합니다."},{"jp":"家から駅まで10分です。","rom":"Ie kara eki made juppun desu.","ko":"집에서 역까지 10분입니다."}],"note":"한국어 '부터/까지'와 1:1 대응"},
    {"pattern":"〜より","ko":"~보다 (비교)","conn":"명사 + より","ex":[{"jp":"日本語は英語より簡単です。","rom":"Nihongo wa Eigo yori kantan desu.","ko":"일본어는 영어보다 간단합니다."},{"jp":"今日は昨日より暑いです。","rom":"Kyō wa kinō yori atsui desu.","ko":"오늘은 어제보다 덥습니다."}]},
    {"pattern":"〜のほうが","ko":"~쪽이 (비교 선택)","conn":"명사 + のほうが + 형용사","ex":[{"jp":"犬より猫のほうが好きです。","rom":"Inu yori neko no hō ga suki desu.","ko":"개보다 고양이 쪽을 더 좋아합니다."},{"jp":"電車のほうが速いです。","rom":"Densha no hō ga hayai desu.","ko":"전철 쪽이 빠릅니다."}]},
    {"pattern":"〜か (의문)","ko":"~입니까? (의문문)","conn":"문장 + か","ex":[{"jp":"学生ですか。","rom":"Gakusei desu ka.","ko":"학생입니까?"},{"jp":"何を食べますか。","rom":"Nani o tabemasu ka.","ko":"무엇을 먹습니까?"}],"note":"물음표 없이 か만으로 의문문이 됨"},
    {"pattern":"〜ね / 〜よ","ko":"~네요 / ~예요(강조)","conn":"문장 끝 + ね/よ","ex":[{"jp":"今日は暑いですね。","rom":"Kyō wa atsui desu ne.","ko":"오늘은 덥네요."},{"jp":"この店はおいしいですよ。","rom":"Kono mise wa oishii desu yo.","ko":"이 가게는 맛있어요(강조)."}],"note":"ね는 공감(~네요), よ는 정보 전달(~라니까요)"},
    {"pattern":"동사 ます형","ko":"~합니다 (정중형)","conn":"동사 어간 + ます","ex":[{"jp":"毎日日本語を勉強します。","rom":"Mainichi Nihongo o benkyō shimasu.","ko":"매일 일본어를 공부합니다."},{"jp":"朝6時に起きます。","rom":"Asa rokuji ni okimasu.","ko":"아침 6시에 일어납니다."}],"note":"한국어 '합니다체'와 동일 개념"},
    {"pattern":"〜ません / 〜ました / 〜ませんでした","ko":"~하지 않습니다 / ~했습니다 / ~하지 않았습니다","conn":"동사 어간 + ません/ました","ex":[{"jp":"肉を食べません。","rom":"Niku o tabemasen.","ko":"고기를 먹지 않습니다."},{"jp":"昨日映画を見ました。","rom":"Kinō eiga o mimashita.","ko":"어제 영화를 봤습니다."}],"note":"가다→갑니다/가지 않습니다/갔습니다 와 같은 어미 갈아끼우기"},
    {"pattern":"〜ましょう / 〜ませんか","ko":"~합시다 / ~하지 않을래요?","conn":"동사 어간 + ましょう/ませんか","ex":[{"jp":"一緒に行きましょう。","rom":"Issho ni ikimashō.","ko":"같이 갑시다."},{"jp":"お茶を飲みませんか。","rom":"Ocha o nomimasen ka.","ko":"차를 마시지 않을래요?"}]},
    {"pattern":"い형용사","ko":"~다/~습니다 (い형용사 기본·정중)","conn":"〜い + です","ex":[{"jp":"この本はおもしろいです。","rom":"Kono hon wa omoshiroi desu.","ko":"이 책은 재미있습니다."},{"jp":"今日は寒いです。","rom":"Kyō wa samui desu.","ko":"오늘은 춥습니다."}]},
    {"pattern":"い형용사 부정·과거","ko":"~지 않다 / ~였다","conn":"〜くない / 〜かった","ex":[{"jp":"高くないです。","rom":"Takakunai desu.","ko":"비싸지 않습니다."},{"jp":"昨日は暑かったです。","rom":"Kinō wa atsukatta desu.","ko":"어제는 더웠습니다."}],"note":"いい(좋다)만 불규칙: よくない, よかった"},
    {"pattern":"な형용사","ko":"~합니다 (な형용사)","conn":"어간 + です / 어간 + な + 명사","ex":[{"jp":"この町は静かです。","rom":"Kono machi wa shizuka desu.","ko":"이 동네는 조용합니다."},{"jp":"きれいな花ですね。","rom":"Kirei na hana desu ne.","ko":"예쁜 꽃이네요."}],"note":"명사 수식 시 な가 붙음"},
    {"pattern":"〜くて / 〜で (형용사 연결)","ko":"~고, ~아서 (연결형)","conn":"い형용사→〜くて / な형용사→〜で","ex":[{"jp":"安くておいしい店です。","rom":"Yasukute oishii mise desu.","ko":"싸고 맛있는 가게입니다."},{"jp":"静かできれいな部屋です。","rom":"Shizuka de kirei na heya desu.","ko":"조용하고 깨끗한 방입니다."}]},
    {"pattern":"〜があります / います","ko":"~이 있습니다 (사물/사람)","conn":"사물 + があります / 생물 + がいます","ex":[{"jp":"机の上に本があります。","rom":"Tsukue no ue ni hon ga arimasu.","ko":"책상 위에 책이 있습니다."},{"jp":"教室に学生がいます。","rom":"Kyōshitsu ni gakusei ga imasu.","ko":"교실에 학생이 있습니다."}],"note":"⚠️ 한국어와 갈라지는 지점: 무생물=ある, 생물=いる 구분"},
    {"pattern":"〜がほしい","ko":"~을 갖고 싶다","conn":"명사 + がほしい","ex":[{"jp":"新しいパソコンがほしいです。","rom":"Atarashii pasokon ga hoshii desu.","ko":"새 컴퓨터를 갖고 싶습니다."},{"jp":"時間がほしいです。","rom":"Jikan ga hoshii desu.","ko":"시간이 필요해요(갖고 싶어요)."}],"note":"조사가 を가 아니라 が인 것에 주의"},
    {"pattern":"〜たい","ko":"~하고 싶다","conn":"동사 어간 + たい","ex":[{"jp":"日本に行きたいです。","rom":"Nihon ni ikitai desu.","ko":"일본에 가고 싶습니다."},{"jp":"寿司が食べたいです。","rom":"Sushi ga tabetai desu.","ko":"초밥이 먹고 싶습니다."}]},
    {"pattern":"동사 て형","ko":"~하고, ~해서 (연결)","conn":"1그룹 음편 주의: 行く→行って","ex":[{"jp":"朝起きて、顔を洗います。","rom":"Asa okite, kao o araimasu.","ko":"아침에 일어나서 세수합니다."},{"jp":"バスに乗って学校へ行きます。","rom":"Basu ni notte gakkō e ikimasu.","ko":"버스를 타고 학교에 갑니다."}],"note":"⚠️ 음편(く→いて, む→んで 등)은 한국어에 없는 변형"},
    {"pattern":"〜てください","ko":"~해 주세요","conn":"て형 + ください","ex":[{"jp":"ここに名前を書いてください。","rom":"Koko ni namae o kaite kudasai.","ko":"여기에 이름을 써 주세요."},{"jp":"ゆっくり話してください。","rom":"Yukkuri hanashite kudasai.","ko":"천천히 말해 주세요."}]},
    {"pattern":"〜ています (진행)","ko":"~하고 있습니다","conn":"て형 + います","ex":[{"jp":"今、ごはんを食べています。","rom":"Ima, gohan o tabete imasu.","ko":"지금 밥을 먹고 있습니다."},{"jp":"雨が降っています。","rom":"Ame ga futte imasu.","ko":"비가 내리고 있습니다."}]},
    {"pattern":"〜ています (상태·직업)","ko":"~하고 있다 (계속 상태)","conn":"て형 + います","ex":[{"jp":"ソウルに住んでいます。","rom":"Souru ni sunde imasu.","ko":"서울에 살고 있습니다."},{"jp":"銀行で働いています。","rom":"Ginkō de hataraite imasu.","ko":"은행에서 일하고 있습니다."}]},
    {"pattern":"〜てもいいです","ko":"~해도 됩니다 (허가)","conn":"て형 + もいいです","ex":[{"jp":"写真を撮ってもいいですか。","rom":"Shashin o totte mo ii desu ka.","ko":"사진을 찍어도 됩니까?"},{"jp":"ここに座ってもいいですよ。","rom":"Koko ni suwatte mo ii desu yo.","ko":"여기에 앉아도 돼요."}]},
    {"pattern":"〜てはいけません","ko":"~하면 안 됩니다 (금지)","conn":"て형 + はいけません","ex":[{"jp":"ここでタバコを吸ってはいけません。","rom":"Koko de tabako o sutte wa ikemasen.","ko":"여기서 담배를 피우면 안 됩니다."},{"jp":"廊下を走ってはいけません。","rom":"Rōka o hashitte wa ikemasen.","ko":"복도를 뛰면 안 됩니다."}]},
    {"pattern":"동사 た형","ko":"~했다 (과거 반말)","conn":"て형과 같은 음편: 行く→行った","ex":[{"jp":"昨日、映画を見た。","rom":"Kinō, eiga o mita.","ko":"어제 영화를 봤다."},{"jp":"友達に会った。","rom":"Tomodachi ni atta.","ko":"친구를 만났다."}]},
    {"pattern":"〜たことがあります","ko":"~한 적이 있습니다 (경험)","conn":"た형 + ことがあります","ex":[{"jp":"日本に行ったことがあります。","rom":"Nihon ni itta koto ga arimasu.","ko":"일본에 간 적이 있습니다."},{"jp":"寿司を食べたことがありますか。","rom":"Sushi o tabeta koto ga arimasu ka.","ko":"초밥을 먹어 본 적이 있습니까?"}]},
    {"pattern":"〜たり〜たりします","ko":"~하거나 ~하거나 합니다","conn":"た형 + り + た형 + り + します","ex":[{"jp":"週末は本を読んだり、映画を見たりします。","rom":"Shūmatsu wa hon o yondari, eiga o mitari shimasu.","ko":"주말에는 책을 읽거나 영화를 보거나 합니다."},{"jp":"歌ったり踊ったりしました。","rom":"Utattari odottari shimashita.","ko":"노래하거나 춤추거나 했습니다."}]},
    {"pattern":"동사 ない형","ko":"~하지 않다 (부정 반말)","conn":"1그룹: う단→あ단+ない","ex":[{"jp":"朝ごはんを食べない。","rom":"Asagohan o tabenai.","ko":"아침밥을 먹지 않는다."},{"jp":"今日は行かない。","rom":"Kyō wa ikanai.","ko":"오늘은 가지 않는다."}]},
    {"pattern":"〜ないでください","ko":"~하지 마세요","conn":"ない형 + でください","ex":[{"jp":"ここで写真を撮らないでください。","rom":"Koko de shashin o toranaide kudasai.","ko":"여기서 사진을 찍지 마세요."},{"jp":"心配しないでください。","rom":"Shinpai shinaide kudasai.","ko":"걱정하지 마세요."}]},
    {"pattern":"〜なければなりません","ko":"~하지 않으면 안 됩니다 (의무)","conn":"ない형(ない삭제) + なければなりません","ex":[{"jp":"明日早く起きなければなりません。","rom":"Ashita hayaku okinakereba narimasen.","ko":"내일 일찍 일어나야 합니다."},{"jp":"宿題をしなければなりません。","rom":"Shukudai o shinakereba narimasen.","ko":"숙제를 해야 합니다."}]},
    {"pattern":"〜なくてもいいです","ko":"~하지 않아도 됩니다","conn":"ない형(ない삭제) + なくてもいいです","ex":[{"jp":"明日は来なくてもいいです。","rom":"Ashita wa konakute mo ii desu.","ko":"내일은 오지 않아도 됩니다."},{"jp":"全部食べなくてもいいですよ。","rom":"Zenbu tabenakute mo ii desu yo.","ko":"다 먹지 않아도 돼요."}]},
    {"pattern":"〜ながら","ko":"~하면서","conn":"동사 어간 + ながら","ex":[{"jp":"音楽を聞きながら勉強します。","rom":"Ongaku o kikinagara benkyō shimasu.","ko":"음악을 들으면서 공부합니다."},{"jp":"コーヒーを飲みながら話しましょう。","rom":"Kōhī o nominagara hanashimashō.","ko":"커피를 마시면서 이야기합시다."}]},
    {"pattern":"〜とき","ko":"~할 때","conn":"동사/형용사 보통형 + とき","ex":[{"jp":"子供のとき、東京に住んでいました。","rom":"Kodomo no toki, Tōkyō ni sunde imashita.","ko":"어렸을 때 도쿄에 살았습니다."},{"jp":"暇なとき、何をしますか。","rom":"Hima na toki, nani o shimasu ka.","ko":"한가할 때 무엇을 합니까?"}]},
    {"pattern":"〜前に / 〜後で","ko":"~하기 전에 / ~한 후에","conn":"사전형 + 前に / た형 + 後で","ex":[{"jp":"寝る前に歯を磨きます。","rom":"Neru mae ni ha o migakimasu.","ko":"자기 전에 이를 닦습니다."},{"jp":"ごはんを食べた後で、散歩します。","rom":"Gohan o tabeta ato de, sanpo shimasu.","ko":"밥을 먹은 후에 산책합니다."}]},
    {"pattern":"〜てから","ko":"~하고 나서","conn":"て형 + から","ex":[{"jp":"シャワーを浴びてから寝ます。","rom":"Shawā o abite kara nemasu.","ko":"샤워를 하고 나서 잡니다."},{"jp":"仕事が終わってから飲みに行きました。","rom":"Shigoto ga owatte kara nomi ni ikimashita.","ko":"일이 끝나고 나서 마시러 갔습니다."}]},
    {"pattern":"もう / まだ","ko":"벌써, 이미 / 아직","conn":"もう + 긍정 / まだ + 부정","ex":[{"jp":"もう宿題をしました。","rom":"Mō shukudai o shimashita.","ko":"벌써 숙제를 했습니다."},{"jp":"まだ食べていません。","rom":"Mada tabete imasen.","ko":"아직 먹지 않았습니다."}],"note":"'아직 ~하지 않았다'는 〜ていません을 씀"},
    {"pattern":"〜だけ / 〜しか〜ない","ko":"~만, ~뿐 / ~밖에 없다","conn":"명사 + だけ / 명사 + しか + 부정","ex":[{"jp":"一つだけください。","rom":"Hitotsu dake kudasai.","ko":"하나만 주세요."},{"jp":"千円しかありません。","rom":"Sen'en shika arimasen.","ko":"천 엔밖에 없습니다."}],"note":"しか는 반드시 부정문과 함께. 한국어 '밖에'와 동일"},
    {"pattern":"〜が好き / 上手 / 下手","ko":"~을 좋아하다 / 잘하다 / 못하다","conn":"명사 + が + 好き/上手/下手","ex":[{"jp":"音楽が好きです。","rom":"Ongaku ga suki desu.","ko":"음악을 좋아합니다."},{"jp":"彼は料理が上手です。","rom":"Kare wa ryōri ga jōzu desu.","ko":"그는 요리를 잘합니다."}],"note":"조사가 を가 아니라 が"},
    {"pattern":"〜になります / 〜くなります","ko":"~이 됩니다 / ~해집니다 (변화)","conn":"명사·な형용사 + になる / い형용사 + くなる","ex":[{"jp":"医者になりたいです。","rom":"Isha ni naritai desu.","ko":"의사가 되고 싶습니다."},{"jp":"だんだん暖かくなりました。","rom":"Dandan atatakaku narimashita.","ko":"점점 따뜻해졌습니다."}]}
  ]
}
